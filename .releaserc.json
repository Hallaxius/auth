{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    "@semantic-release/npm",
    [
      "@semantic-release/github",
      {
        "failComment": false,
        "failTitle": false
      }
    ]
  ],
  "npm": {
    "pkgRoot": ".",
    "tarballDir": "dist"
  },
  "github": {
    "successComment": "npm release published successfully"
  }
}
