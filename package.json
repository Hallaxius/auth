{
  "name": "@hallaxius/auth",
  "version": "2.1.0",
  "description": "Plug-and-play authentication for Bun and Next.js. Supports Discord OAuth2 and credentials (username/password) auth with JWT sessions, role-based access control, and edge-compatible middleware.",
  "author": {
    "name": "hallaxius",
    "url": "https://github.com/hallaxius"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./elysia": {
      "types": "./dist/elysia/plugin.d.ts",
      "import": "./dist/elysia/plugin.js"
    },
    "./adapters/redis": {
      "types": "./dist/adapters/redis/index.d.ts",
      "import": "./dist/adapters/redis/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build --target=bun --outdir=dist ./src/index.ts ./src/elysia/plugin.ts ./src/adapters/redis/index.ts && tsc -p tsconfig.build.json --outDir dist",
    "dev": "bun --watch run src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "bunx --bun @biomejs/biome check --write --unsafe src/",
    "lint:check": "bunx --bun @biomejs/biome check src/",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "prepublish": "bun run lint && bun run build && bun test"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "ioredis": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    }
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@elysiajs/jwt": "^1.4.2",
    "elysia": "^1.4.29",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/bun": "^1.3.14",
    "@types/ioredis": "^5.0.0",
    "bun-types": "latest",
    "typescript": "^5.9.0"
  },
  "keywords": [
    "authentication",
    "oauth2",
    "discord",
    "credentials",
    "username-password",
    "jwt",
    "session-management",
    "rbac",
    "role-based-access-control",
    "middleware",
    "bun",
    "elysia",
    "nextjs",
    "edge-runtime",
    "csrf-protection",
    "pkce",
    "rate-limiting",
    "discord-api",
    "discord-oauth",
    "auth-provider",
    "redis"
  ],
  "bugs": {
    "url": "https://github.com/hallaxius/auth/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hallaxius/auth.git"
  },
  "homepage": "https://github.com/hallaxius/auth"
}
