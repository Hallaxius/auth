{
	"name": "@hallaxius/auth",
	"version": "5.3.0",
	"description": "Complete authentication for Bun and Next.js 16+. Discord OAuth2, credentials, MFA (TOTP), password reset, rate limiting, and edge-compatible middleware.",
	"author": {
		"name": "hallaxius",
		"url": "https://github.com/hallaxius"
	},
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bun build --target=bun --outdir=dist ./src/index.ts && tsc -p tsconfig.build.json --outDir dist",
		"dev": "bun build --target=bun --outdir=dist ./src/index.ts --watch",
		"typecheck": "tsc --noEmit",
		"lint": "bunx --bun @biomejs/biome check --write --unsafe src/",
		"lint:check": "bunx --bun @biomejs/biome check src/",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"test:coverage": "bun test --coverage",
		"test:unit": "vitest run",
		"test:unit:coverage": "vitest run --coverage",
		"test:unit:watch": "vitest watch",
		"test:integration": "bun test tests/integration/**/*.test.ts",
		"test:security": "bun test tests/security/**/*.test.ts",
		"test:performance": "bun test tests/performance/**/*.test.ts",
		"test:load": "bun test tests/performance/load-tests.ts",
		"test:stress": "bun test tests/performance/stress-tests.ts",
		"test:endurance": "bun test tests/performance/endurance-tests.ts",
		"test:spike": "bun test tests/performance/spike-tests.ts",
		"test:all": "bun test --coverage",
		"test:baseline": "bun run tests/performance/run-baseline.ts",
		"benchmark": "bun run tests/performance/benchmark-runner.ts",
		"docs": "typedoc",
		"prepublishOnly": "bun run build && bun run test:all"
	},
	"peerDependencies": {
		"next": ">=16.0.0 <17.0.0"
	},
	"peerDependenciesMeta": {
		"next": {
			"optional": true
		}
	},
	"engines": {
		"bun": ">=1.0.0"
	},
	"dependencies": {
		"jose": "^6.2.4",
		"redis": "^6.1.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.5",
		"@types/bun": "^1.3.14",
		"@vitest/coverage-v8": "^4.1.10",
		"bun-types": "latest",
		"typedoc": "^0.25.0",
		"typescript": "^5.7.2",
		"vitest": "^4.1.10"
	},
	"keywords": [
		"authentication",
		"oauth2",
		"discord",
		"credentials",
		"username-password",
		"jwt",
		"session-management",
		"rbac",
		"role-based-access-control",
		"middleware",
		"bun",
		"nextjs",
		"nextjs-16",
		"proxy",
		"edge-runtime",
		"csrf-protection",
		"pkce",
		"rate-limiting",
		"discord-api",
		"discord-oauth",
		"auth-provider",
		"password-reset",
		"mfa",
		"totp",
		"backup-codes",
		"pbkdf2",
		"rfc-8587"
	],
	"bugs": {
		"url": "https://github.com/hallaxius/auth/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/hallaxius/auth.git"
	},
	"homepage": "https://github.com/hallaxius/auth"
}
