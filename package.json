{
	"name": "@hallaxius/auth",
	"version": "4.0.0",
	"description": "Plug-and-play authentication for Bun and Next.js 16+. Supports Discord OAuth2, credentials (username/password) auth with JWT sessions, password reset, MFA (TOTP + backup codes), rate limiting, role-based access control, and edge-compatible middleware. v4: security hardening (PBKDF2, JWT jti, RFC 8587 headers), breaking interface updates (required config fields, consolidated types), GuildRoleSync class export.",
	"author": {
		"name": "hallaxius",
		"url": "https://github.com/hallaxius"
	},
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bun build --target=bun --outdir=dist ./src/index.ts && tsc -p tsconfig.build.json --outDir dist",
		"dev": "bun build --target=bun --outdir=dist ./src/index.ts --watch",
		"typecheck": "tsc --noEmit",
		"lint": "bunx --bun @biomejs/biome check --write --unsafe src/",
		"lint:check": "bunx --bun @biomejs/biome check src/",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"test:coverage": "bun test --coverage",
		"prepublish": "bun run lint && bun run build && bun test"
	},
	"peerDependencies": {
		"next": ">=16.0.0 <17.0.0"
	},
	"peerDependenciesMeta": {
		"next": {
			"optional": true
		}
	},
	"engines": {
		"bun": ">=1.0.0"
	},
	"dependencies": {
		"jose": "^6.2.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.4",
		"@types/bun": "^1.3.14",
		"bun-types": "latest",
		"typescript": "7.0.2"
	},
	"keywords": [
		"authentication",
		"oauth2",
		"discord",
		"credentials",
		"username-password",
		"jwt",
		"session-management",
		"rbac",
		"role-based-access-control",
		"middleware",
		"bun",
		"nextjs",
		"nextjs-16",
		"proxy",
		"edge-runtime",
		"csrf-protection",
		"pkce",
		"rate-limiting",
		"discord-api",
		"discord-oauth",
		"auth-provider",
		"password-reset",
		"mfa",
		"totp",
		"backup-codes",
		"pbkdf2",
		"rfc-8587"
	],
	"bugs": {
		"url": "https://github.com/hallaxius/auth/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/hallaxius/auth.git"
	},
	"homepage": "https://github.com/hallaxius/auth"
}
