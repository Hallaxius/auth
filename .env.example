# @hallaxius/auth - Environment Variables

# Required: Secret key for JWT signing and encryption
AUTH_SECRET=your-256-bit-secret-key-here

# Discord OAuth2
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_CALLBACK_URL=http://localhost:3000/auth/discord/callback

# Optional: Database connection for persistent storage
# DATABASE_URL=postgresql://user:password@localhost:5432/auth

# Optional: SMTP for password reset emails
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-email-password
# SMTP_FROM=noreply@example.com
